# Kimi API Key (Moonshot AI)
# 获取地址: https://platform.moonshot.cn
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_API_URL=https://api.moonshot.cn

# Fish Audio API Key
# 获取地址: https://fish.audio
FISH_AUDIO_KEY=your-fish-audio-api-key

# Fish Audio 声音模型 ID (可选，不填则使用默认声音)
# 在 Fish Audio 网站上创建/选择声音后获取
FISH_AUDIO_REFERENCE_ID=

# Optional production settings
PORT=3001
CORS_ORIGIN=https://your-kunadio-domain.example
